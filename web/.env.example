# Omit VITE_API_URL for local dev/preview so the app uses `/api` (Vite proxies to the backend).
# Set it for production builds when the API is on a different host than the static UI.
# VITE_API_URL=https://farmapi.clevacredit.com
VITE_APP_VERSION=1.0.0

# Streamlit “Business Model” app (run: streamlit run app.py in that repo). Used by /cleva/business-model.
# Defaults to http://127.0.0.1:8501 if unset. Iframes may be blocked cross-origin; use “Open in new tab” on the page.
# VITE_BUSINESS_MODEL_URL=https://analytics.example.com
